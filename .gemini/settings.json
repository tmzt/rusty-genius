{
  "tools": {
    "core": [
      "list_directory",
      "glob",
      "read_file",
      "search_file_content",
      "write_file",
      "replace",
      "run_shell_command(git status)",
      "run_shell_command(git worktree add)",
      "run_shell_command(git worktree list)",
      "run_shell_command(git worktree prune)",
      "run_shell_command(git commit)",
      "run_shell_command(git merge)",
      "run_shell_command(git checkout)",
      "run_shell_command(git branch)",
      "run_shell_command(git push)",
      "run_shell_command(cargo build)",
      "run_shell_command(cargo check)",
      "run_shell_command(npm install)",
      "run_shell_command(npm run build)",
      "run_shell_command(yarn install)",
      "run_shell_command(ls)",
      "run_shell_command(cat)",
      "run_shell_command(mkdir)",
      "run_shell_command(touch)",
      "run_shell_command(grep)",
      "run_shell_command(sed)",
      "run_shell_command(./scripts)"
    ],
    "exclude": [
      "run_shell_command(git reset --hard)",
      "run_shell_command(git rebase)",
      "run_shell_command(git worktree remove)",
      "run_shell_command(rm)",
      "run_shell_command(shred)",
      "run_shell_command(dd)",
      "run_shell_command(mkfs)"
    ],
    "shell": {
      "enableInteractiveShell": true
    }
  },
  "fileFiltering": {
    "respectGitIgnore": true
  }
}
